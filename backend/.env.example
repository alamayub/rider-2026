PORT=4000
NODE_ENV=development
JWT_SECRET=change-me
CORS_ORIGIN=http://localhost:3000
COMMISSION_RATE_PERCENT=20
WEBHOOK_SECRET=change-me-webhook
WEBHOOK_MAX_SKEW_SECONDS=300
ENABLED_PAYMENT_PROVIDERS=esewa,khalti,fonepay,connectips
ESEWA_BASE_URL=https://epay.esewa.com.np
KHALTI_BASE_URL=https://khalti.com
FONEPAY_BASE_URL=https://merchantapi.fonepay.com
CONNECTIPS_BASE_URL=https://www.connectips.com

# Notifications / FCM
FCM_ENABLED=false
FCM_SERVER_KEY=
FCM_ENDPOINT=https://fcm.googleapis.com/fcm/send
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=ride
MYSQL_PASSWORD=ride
MYSQL_DATABASE=ride

# First boot with an empty `users` table: in development, seeds admin / rider / driver
# (phones 9800000000 / 9800000001 / 9800000002, password SEED_DEV_PASSWORD or Pass@123).
# Set to 0/false to skip (tests force this off).
# SEED_DEV_USERS=1
# SEED_DEV_PASSWORD=Pass@123
